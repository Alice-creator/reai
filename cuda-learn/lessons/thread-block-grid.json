  "html_content": "<style>.tg-wrap{font-family:monospace;padding:20px 24px;background:#0f172a;color:#e2e8f0}.tg-sec{margin-bottom:22px}.tg-lbl{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-bottom:10px}.grid-row{display:flex;gap:6px;align-items:flex-start;flex-wrap:wrap}.blk{border:1px solid #334155;border-radius:6px;padding:8px 10px}.blk.hi{border-color:#3b82f6;background:#1e3a5f22}.blk-ttl{font-size:10px;color:#64748b;margin-bottom:6px}.blk.hi .blk-ttl{color:#60a5fa}.th-row{display:flex;gap:3px}.th{width:20px;height:20px;border-radius:3px;background:#1e293b;border:1px solid #2d3748;display:flex;align-items:center;justify-content:center;font-size:8px;color:#64748b}.th.hi{background:#1e3a8a;border-color:#3b82f6;color:#93c5fd;font-weight:700}.warp-grid{display:grid;grid-template-columns:repeat(8,1fr);gap:3px;max-width:296px}.wt{height:30px;border-radius:4px;background:#14532d;border:1px solid #22c55e;display:flex;align-items:center;justify-content:center;font-size:9px;color:#86efac;font-weight:600}.fbar{background:#1e293b;border:1px solid #334155;border-radius:8px;padding:12px 16px;font-size:12px;line-height:2.2}.kw{color:#818cf8}.val{color:#34d399;font-weight:700}.eq{color:#f59e0b}.dim{color:#64748b}.note{font-size:10px;color:#475569;margin-top:6px}</style><div class='tg-wrap'><div class='tg-sec'><div class='tg-lbl'>Grid → Thread Blocks → Threads &nbsp;(1D: 4 blocks × 4 threads = 16 threads total)</div><div class='grid-row'><div class='blk'><div class='blk-ttl'>Block 0</div><div class='th-row'><div class='th'>0</div><div class='th'>1</div><div class='th'>2</div><div class='th'>3</div></div></div><div class='blk hi'><div class='blk-ttl'>Block 1 &nbsp;&#8592; blockIdx.x=1</div><div class='th-row'><div class='th'>0</div><div class='th'>1</div><div class='th hi'>2</div><div class='th'>3</div></div><div class='note'>threadIdx.x = 0..3</div></div><div class='blk'><div class='blk-ttl'>Block 2</div><div class='th-row'><div class='th'>0</div><div class='th'>1</div><div class='th'>2</div><div class='th'>3</div></div></div><div class='blk'><div class='blk-ttl'>Block 3</div><div class='th-row'><div class='th'>0</div><div class='th'>1</div><div class='th'>2</div><div class='th'>3</div></div></div></div></div><div class='tg-sec'><div class='tg-lbl'>1 Warp = 32 threads — chạy cùng 1 instruction đồng thời (SIMT)</div><div class='warp-grid'><div class='wt'>0</div><div class='wt'>1</div><div class='wt'>2</div><div class='wt'>3</div><div class='wt'>4</div><div class='wt'>5</div><div class='wt'>6</div><div class='wt'>7</div><div class='wt'>8</div><div class='wt'>9</div><div class='wt'>10</div><div class='wt'>11</div><div class='wt'>12</div><div class='wt'>13</div><div class='wt'>14</div><div class='wt'>15</div><div class='wt'>16</div><div class='wt'>17</div><div class='wt'>18</div><div class='wt'>19</div><div class='wt'>20</div><div class='wt'>21</div><div class='wt'>22</div><div class='wt'>23</div><div class='wt'>24</div><div class='wt'>25</div><div class='wt'>26</div><div class='wt'>27</div><div class='wt'>28</div><div class='wt'>29</div><div class='wt'>30</div><div class='wt'>31</div></div><div class='note'>blockDim=256 → 8 warps/block &nbsp;·&nbsp; if/else trong warp → serialize → chậm (warp divergence)</div></div><div class='fbar'><div><span class='dim'>Global index:</span> &nbsp;<span class='kw'>globalIdx</span> <span class='eq'>=</span> blockIdx.x <span class='eq'>×</span> blockDim.x <span class='eq'>+</span> threadIdx.x</div><div><span class='dim'>Ví dụ blockIdx=</span><span class='val'>1</span><span class='dim'>, blockDim=</span><span class='val'>4</span><span class='dim'>, threadIdx=</span><span class='val'>2</span> <span class='eq'>→</span> <span class='val'>1×4+2 = 6</span></div></div></div>"
